# 複製此檔案為 .env 並填入你的設定
# cp .env.example .env

# LINE Messaging API（前往 https://developers.line.biz/ 申請）
LINE_CHANNEL_TOKEN=你的_Channel_Access_Token
LINE_USER_ID=你的_User_ID（格式：Uxxxxxxxxxx）

# 追蹤股票（逗號分隔，不含空格）
TW_STOCKS=2330.TW,2317.TW,2454.TW
US_STOCKS=AAPL,NVDA,TSLA

# 警報門檻（可選，有預設值）
ALERT_DROP_PCT=-3.0
ALERT_RISE_PCT=5.0

# 發送時間，台灣時間（可選，有預設值）
TW_MARKET_CLOSE=14:35
US_MARKET_CLOSE=05:10
